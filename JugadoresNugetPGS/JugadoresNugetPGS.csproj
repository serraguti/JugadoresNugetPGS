<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Jugadores XML</Title>
    <Description>Nuget con jugadores XML Assembly</Description>
    <PackageIcon>user.png</PackageIcon>
    <PackageTags>players,jugadores,pgs,champions,miercoles</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="jugadores.xml" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="jugadores.xml" />
  </ItemGroup>

  <ItemGroup>
    <None Update="user.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
